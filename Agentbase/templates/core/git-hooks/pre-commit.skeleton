#!/bin/bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Pre-commit Hook — Bootstrap tarafindan uretilmistir
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Bu hook Codebase'de git commit yapildiginda calisir.
# Kurulum: cd ../Codebase && git config core.hooksPath "$(realpath ../Agentbase/git-hooks/)"
#
# Bypass: TESTS_VERIFIED=1 git commit -m "..."
#
# Kontroller:
#   1. Guvenlik taramasi (hardcoded secret, .env dosyasi)
#   2. Derleme kontrolu (TypeScript, Go, Rust — stack'e gore)
#   3. Test calistirma (jest, pytest, phpunit — stack'e gore)
#   4. Lint kontrolu (eslint, phpcs, ruff — stack'e gore)
#   5. Format kontrolu (prettier, biome — stack'e gore)

# ─── TESTS_VERIFIED BYPASS ───
if [ "${TESTS_VERIFIED}" = "1" ]; then
  echo "✓ TESTS_VERIFIED=1 — pre-commit kontrolleri atlaniyor"
  exit 0
fi

ERRORS=0
CODEBASE_DIR="$(git rev-parse --show-toplevel)"

echo ""
echo "━━━ Pre-commit Kontrolleri ━━━"
echo ""

# ─── GUVENLIK TARAMASI ───
# Staged dosyalarda hardcoded secret ve .env dosyasi arar
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -n "$STAGED_FILES" ]; then
  # .env dosyasi commit kontrolu
  ENV_FILES=$(echo "$STAGED_FILES" | grep -E '\.env$|\.env\.local$|\.env\.production$|\.env\.staging$' || true)
  if [ -n "$ENV_FILES" ]; then
    echo "❌ .env dosyasi commit edilemez!"
    echo "   Engellenen dosyalar:"
    echo "$ENV_FILES" | sed 's/^/     /'
    ERRORS=1
  fi

  # Hardcoded secret taramasi (staged diff uzerinde)
  STAGED_DIFF=$(git diff --cached --unified=0 2>/dev/null || true)
  if [ -n "$STAGED_DIFF" ]; then
    # API key pattern'leri
    if echo "$STAGED_DIFF" | grep -qE 'sk-[a-zA-Z0-9]{20,}'; then
      echo "❌ Hardcoded API key tespit edildi (sk-... pattern)!"
      ERRORS=1
    fi
    # AWS access key
    if echo "$STAGED_DIFF" | grep -qE '(AKIA|ASIA)[A-Z0-9]{16}'; then
      echo "❌ AWS access key tespit edildi!"
      ERRORS=1
    fi
    # Private key
    if echo "$STAGED_DIFF" | grep -qE '\-\-\-\-\-BEGIN.*PRIVATE KEY\-\-\-\-\-'; then
      echo "❌ Private key tespit edildi!"
      ERRORS=1
    fi
    # Generic secret assignment (password = "...", secret = "...")
    if echo "$STAGED_DIFF" | grep -qEi '(password|secret|token|api_key)\s*[:=]\s*["\x27][^"\x27]{4,}["\x27]'; then
      echo "⚠️  Olasi hardcoded credential tespit edildi — kontrol edin."
    fi
  fi
fi

# ─── DERLEME KONTROLU ───
<!-- GENERATE: GIT_PRECOMMIT_COMPILE
Stack'e gore derleme kontrolu eklenir:
- TypeScript varsa: npx tsc --noEmit
- Go varsa: go build ./...
- Rust varsa: cargo check
-->

# ─── TEST KONTROLU ───
<!-- GENERATE: GIT_PRECOMMIT_TEST
Stack'e gore test komutu eklenir:
- jest/vitest/mocha: npm test veya npx jest
- pytest: python -m pytest
- phpunit: ./vendor/bin/phpunit
- go test: go test ./...
-->

# ─── LINT KONTROLU ───
<!-- GENERATE: GIT_PRECOMMIT_LINT
Stack'e gore lint kontrolu eklenir:
- eslint: npx eslint --quiet (staged dosyalar)
- biome: npx biome check (staged dosyalar)
- phpcs: ./vendor/bin/phpcs (staged dosyalar)
- ruff: ruff check (staged dosyalar)
-->

# ─── FORMAT KONTROLU ───
<!-- GENERATE: GIT_PRECOMMIT_FORMAT
Formatter varsa staged dosyalari kontrol eder:
- prettier: npx prettier --check (staged dosyalar)
- biome: npx biome format --check (staged dosyalar)
- ruff: ruff format --check (staged dosyalar)
-->

# ─── SONUC ───
echo ""
if [ "$ERRORS" -ne 0 ]; then
  echo "━━━ Pre-commit BASARISIZ ━━━"
  echo "Bypass: TESTS_VERIFIED=1 git commit -m \"...\""
  exit 1
fi

echo "━━━ Pre-commit OK ━━━"
exit 0
