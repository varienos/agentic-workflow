# ─────────────────────────────────────────────────────
# BU PROJE'NIN KENDI GELISTIRME ORTAMI
# (template'in parcasi degil, repo'ya girmez)
# ─────────────────────────────────────────────────────

# Root .claude/ — bu projeyi gelistirmek icin kullanilan CC config
# (task-hunter.md, task-plan.md gibi proje-spesifik komutlar burada)
/.claude/

# Root CLAUDE.md — bu projenin kendi CC talimat dosyasi
/CLAUDE.md

# Root backlog — bu projenin kendi gorev takibi (IGNORE — repoya GIRMEZ)
# Proje-spesifik gorev takibi
/backlog/

# Diger proje-spesifik root dosyalar
AGENTS.md
GEMINI.md

# ─────────────────────────────────────────────────────
# AGENTBASE ICINDEKI BOOTSTRAP URETIMI
# (template'in parcasi degil, hedef proje icin uretilir)
# ─────────────────────────────────────────────────────

# Bootstrap ciktilari — /bootstrap calistirildiktan sonra olusur
Agentbase/.claude/settings.local.json
Agentbase/.claude/settings.json
Agentbase/.claude/CLAUDE.md
Agentbase/.claude/agents/
Agentbase/.claude/hooks/
Agentbase/.claude/rules/
Agentbase/.claude/custom/
Agentbase/.mcp.json
Agentbase/.claude-ignore
Agentbase/CLAUDE.md

# Transform ciktilari (transform.js uretir — hedef CLI yapilandirmalari)
Agentbase/.gemini/
Agentbase/.codex/
Agentbase/.kimi/
Agentbase/.opencode/
Agentbase/GEMINI.md
Agentbase/AGENTS.md

# Runtime verisi (oturum bazli)
Agentbase/.claude/tracking/sessions/session-*.json
Agentbase/.claude/reports/deploys/deploy-*.md
Agentbase/.claude/hooks/.test-reminder-state.json

# Agentbase backlog (hedef proje icin bootstrap uretir)
Agentbase/backlog/

# ─────────────────────────────────────────────────────
# REPO'DA KALAN DOSYALAR (asagidakiler TRACKED):
#
# Agentbase/.claude/commands/bootstrap.md  ← Template'in bootstrap komutu
# Agentbase/templates/                     ← Skeleton dosyalar (template'in ozu)
# Agentbase/generate.js                    ← Deterministik uretim betigi
# Agentbase/bin/session-monitor.js         ← Oturum izleme araci
# Agentbase/tests/                         ← Test suite
# Agentbase/*.md stub'lari                 ← Bootstrap dolduracak
# Docs/superpowers/                        ← Spec ve plan dokumanlari
# ─────────────────────────────────────────────────────

# Test ortami
test/

# Codebase icerigi (kullanici kendi projesini symlink eder)
# Dizin ve .gitkeep tracked, icerik ignore
Codebase/*
!Codebase/.gitkeep

# Docs (Bootstrap uretir — proje-spesifik)
Docs/agentic/project-manifest.yaml
/Docs/superpowers/
